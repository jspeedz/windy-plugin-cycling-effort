{
    "plugins": ["prettier-plugin-svelte"],
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 4,
    "arrowParens": "avoid",
    "useTabs": false,
    "overrides": [{ "files": "*.svelte", "options": { "parser": "svelte" } }],
    "svelteSortOrder": "options-markup-scripts-styles"
}
