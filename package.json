{
    "name": "windy-plugin-cycling-effort",
    "description": "Windy.com plugin for weather-aware cycling route effort scoring.",
    "main": "dist/plugin.min.js",
    "keywords": [
        "windy",
        "windy.com",
        "plugins"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jspeedz/windy-plugin-cycling-effort.git"
    },
    "homepage": "https://github.com/jspeedz/windy-plugin-cycling-effort",
    "bugs": {
        "url": "https://github.com/jspeedz/windy-plugin-cycling-effort/issues"
    },
    "version": "0.1.0",
    "type": "module",
    "license": "ISC",
    "private": true,
    "scripts": {
        "start": "rollup -cw",
        "build": "rm -rf dist && mkdir dist && SERVE=false rollup -c && cp package.json dist/",
        "test": "TZ=UTC vitest run --config=vite.config.mjs",
        "test:coverage": "TZ=UTC vitest run --coverage --config=vite.config.mjs",
        "test:watch": "TZ=UTC vitest run --watch --config=vite.config.mjs",
        "test:watch:ui": "TZ=UTC vitest run --watch --ui --coverage --config=vite.config.mjs",
        "lint": "eslint . --fix",
        "lint:ci": "eslint .",
        "prettier:check": "prettier . --check \"!.docker/**\" \"!.vendor/**\" \"!.node_modules/**\"",
        "prettier:write": "prettier . --write \"!.docker/**\" \"!.vendor/**\" \"!.node_modules/**\"",
        "pre-commit": "npm run prettier:write && npm run lint"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^25.0.7",
        "@rollup/plugin-node-resolve": "^15.2.3",
        "@rollup/plugin-terser": "^0.4.4",
        "@windycom/plugin-devtools": "3.0.3",
        "rollup": "^4.9.6",
        "rollup-plugin-cleanup": "^3.2.1",
        "rollup-plugin-serve": "^1.1.1",
        "rollup-plugin-svelte": "^7.1.6",
        "svelte": "^4.2.9",
        "vite": "^8.0.0",
        "vitest": "^4.1.0"
    }
}
